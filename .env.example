# ---------------------------------------------------------------------------
# Menu Management API — environment variables
# ---------------------------------------------------------------------------
# Copy to `.env` and edit for local development. All values have sensible
# defaults in src/app/config.py; anything here simply overrides them.
# ---------------------------------------------------------------------------

# Database connection string.
#   - SQLite (default, zero-config for demos): sqlite:///./menu.db
#   - PostgreSQL (production target):          postgresql+psycopg://user:pass@localhost:5432/menu
DATABASE_URL=sqlite:///./menu.db

# JWT signing. Generate a real secret with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# !!! DEMO ONLY — DISABLE BEFORE DEPLOYING !!!
# ---------------------------------------------------------------------------
# When true, POST /auth/register is publicly accessible — ANY unauthenticated
# caller can self-provision an account, including with role=admin. This is
# intended only for local demos and CI. In production set this to `false`
# (or delete it — false is the default) so that only existing admins can
# create new users.
# ---------------------------------------------------------------------------
DEV_ALLOW_OPEN_REGISTRATION=true

# Uvicorn-facing.
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
